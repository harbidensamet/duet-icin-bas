# Firebase Admin SDK service account JSON dosyasının yolu
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase Realtime Database URL (örn: https://projeniz-default-rtdb.firebaseio.com)
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com

# YouTube Data API v3 key (console.cloud.google.com)
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY

# YouTube Live Stream Video ID (yayın başladıktan sonra URL'deki v= parametresi)
# Boş bırakılırsa channel'ın aktif yayını otomatik bulunur
YOUTUBE_VIDEO_ID=

# YouTube Channel ID (YOUTUBE_VIDEO_ID boşsa aktif yayın buradan aranır)
YOUTUBE_CHANNEL_ID=YOUR_CHANNEL_ID

# TikTok kullanıcı adı (@ olmadan)
TIKTOK_USERNAME=YOUR_TIKTOK_USERNAME

# Takip edilecek emoji/kelime
TRIGGER_EMOJI=🎵

# Backend port
PORT=3001
